# Configuration Email System PGI-IA

## Microsoft OAuth2 Configuration
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_REDIRECT_URI=http://localhost:5000/auth/callback

## Email Service Settings
EMAIL_CHECK_INTERVAL=60  # secondes
EMAIL_BATCH_SIZE=50      # emails par batch
EMAIL_TIMEOUT=30         # timeout par email

## Filtres Email
# Domaines autorisés (séparés par virgules)
ALLOWED_DOMAINS=kahnawake.com,alexisnihon.ca,drelectrique.com,constructionxyz.com

# Mots-clés déclencheurs
TRIGGER_KEYWORDS=directive,plan,révision,changement,modification,drawing,schéma

# Exclusions
EXCLUDE_SENDERS=noreply@,automated@,notification@

## Classification IA
# Modèle à utiliser
EMAIL_CLASSIFIER_MODEL=deepseek-email-v1

# Seuils de confiance
AUTO_PROCESS_THRESHOLD=0.95    # Traitement automatique
MANUAL_REVIEW_THRESHOLD=0.80   # Revue manuelle requise
REJECT_THRESHOLD=0.50          # Rejet automatique

# Cache
ENABLE_CLASSIFICATION_CACHE=true
CACHE_EXPIRY_HOURS=24

## Actions Automatiques
# Directives
AUTO_CREATE_DIRECTIVES=true
DIRECTIVE_NOTIFICATION=true
DIRECTIVE_APPROVAL_REQUIRED=false

# Plans
AUTO_PROCESS_PLANS=true
OCR_PLANS=true
COMPARE_REVISIONS=true
HIGHLIGHT_CHANGES=true

# Questions
AUTO_TAG_QUESTIONS=true
SUGGEST_RESPONSES=true
ROUTE_TO_EXPERT=true

## Sécurité
# Archivage
ARCHIVE_ALL_EMAILS=true
ARCHIVE_RETENTION_DAYS=365

# Encryption
ENCRYPT_EMAIL_BODY=true
ENCRYPTION_KEY=  # Généré automatiquement si vide

# Rate limiting
MAX_EMAILS_PER_MINUTE=100
MAX_ATTACHMENTS_SIZE_MB=50

## Notifications
# WebSocket
ENABLE_REALTIME_NOTIFICATIONS=true
WEBSOCKET_PORT=5001

# Email notifications
SEND_PROCESSING_CONFIRMATIONS=true
ADMIN_EMAIL=admin@drelectrique.com

## Monitoring
# Logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Alerting
ALERT_ON_CLASSIFICATION_FAILURE=true
ALERT_ON_SERVICE_DOWN=true
ALERT_THRESHOLD_MINUTES=5

## Development
# Mode debug
DEBUG_MODE=false
TEST_MODE=false
DRY_RUN=false

# Test email account
TEST_EMAIL_ADDRESS=
TEST_EMAIL_PASSWORD=